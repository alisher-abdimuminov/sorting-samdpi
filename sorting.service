[Unit]
Description=sorting daemon
Requires=sorting.socket
After=network.target

[Service]
User=root
Group=root
WorkingDirectory=/home/ali/sorting/
ExecStart=/home/ali/sorting/.venv/bin/gunicorn \
          --access-logfile - \
          --workers 3 \
          --bind unix:/run/sorting.sock \
          config.wsgi:application

[Install]
WantedBy=multi-user.target